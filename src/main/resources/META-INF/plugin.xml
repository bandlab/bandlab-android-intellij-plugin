<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.bandlab.intellij.plugin</id>
    <name>BandLab Android Convention</name>
    <vendor>BandLab</vendor>

    <dependencies>
        <plugin id="com.intellij.java"/>
        <plugin id="org.jetbrains.android"/>
        <module name="intellij.platform.jewel.foundation"/>
        <module name="intellij.platform.jewel.ui"/>
        <module name="intellij.platform.jewel.ideLafBridge"/>
        <module name="intellij.libraries.compose.foundation.desktop"/>
        <module name="intellij.libraries.skiko"/>
    </dependencies>

    <extensions defaultExtensionNs="com.android">
        <moduleDescriptionProvider
                implementation="com.bandlab.intellij.plugin.module.BandLabModuleDescriptionProvider"
                id="bandlab_convention"/>
    </extensions>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Gradle project path support -->
        <completion.contributor
                language="Groovy"
                implementationClass="com.bandlab.intellij.plugin.dependencies.autocomplete.GradleProjectCompletionContributor"/>
        <completion.contributor
                language="kotlin"
                implementationClass="com.bandlab.intellij.plugin.dependencies.autocomplete.GradleProjectCompletionContributor"/>
        <annotator
                language="Groovy"
                implementationClass="com.bandlab.intellij.plugin.dependencies.autocomplete.GradleProjectAnnotator"/>
        <annotator
                language="kotlin"
                implementationClass="com.bandlab.intellij.plugin.dependencies.autocomplete.GradleProjectAnnotator"/>
        <psi.referenceContributor
                language="Groovy"
                implementation="com.bandlab.intellij.plugin.dependencies.autocomplete.GradleProjectReferenceContributor"/>
        <psi.referenceContributor
                language="kotlin"
                implementation="com.bandlab.intellij.plugin.dependencies.autocomplete.GradleProjectReferenceContributor"/>
        <intentionAction>
            <className>com.bandlab.intellij.plugin.dependencies.autocomplete.RefreshProjectPathsIntentionAction
            </className>
            <category>Gradle</category>
        </intentionAction>
    </extensions>

    <actions>
        <action id="ActivityTemplateCreateAction"
                class="com.bandlab.intellij.plugin.template.ActivityTemplateCreateAction" text="Activity Template">
            <add-to-group group-id="NewGroup" anchor="before" relative-to-action="Android.CreateResourcesActionGroup"/>
        </action>

        <action id="PageTemplateCreateAction"
                class="com.bandlab.intellij.plugin.template.PageTemplateCreateAction" text="Page Template">
            <add-to-group group-id="NewGroup" anchor="after" relative-to-action="ActivityTemplateCreateAction"/>
        </action>

        <action id="TwoLevelInjectionTemplateCreateAction"
                class="com.bandlab.intellij.plugin.template.TwoLevelInjectionTemplateCreateAction"
                text="2-level Injection Template">
            <add-to-group group-id="NewGroup" anchor="after" relative-to-action="PageTemplateCreateAction"/>
        </action>

        <action id="AutomationTemplateCreateAction"
                class="com.bandlab.intellij.plugin.automation.AutomationTemplateCreateAction"
                text="Automation Template">
            <add-to-group group-id="NewGroup" anchor="after"
                          relative-to-action="TwoLevelInjectionTemplateCreateAction"/>
        </action>

        <action id="SortDependenciesAction"
                class="com.bandlab.intellij.plugin.dependencies.sort.SortDependenciesAction" text="Sort Dependencies">
            <add-to-group group-id="ProjectViewPopupMenuModifyGroup" anchor="first"/>
            <add-to-group group-id="EditorPopupMenu1" anchor="first"/>
        </action>

        <action id="ApplyTestFixturesPluginAction"
                class="com.bandlab.intellij.plugin.test.fixtures.ApplyTestFixturesPluginAction" text="Test Fixtures">
            <add-to-group group-id="ProjectViewPopupMenuModifyGroup" anchor="after"
                          relative-to-action="SortDependenciesAction"/>
            <add-to-group group-id="EditorPopupMenu1" anchor="after" relative-to-action="SortDependenciesAction"/>
        </action>
    </actions>
</idea-plugin>
